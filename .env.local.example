# Supabase — get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Kitchen password (simple auth for the chef panel)
KITCHEN_PASSWORD=your-secret-kitchen-password

# Spotify (optional — for now-playing bar, playlist queue, and kitchen playlist switcher)
# Required scopes for full playlist features:
#   user-read-currently-playing user-read-playback-state
#   playlist-read-private playlist-read-collaborative
#   user-modify-playback-state
# Re-run the OAuth flow with these scopes to generate a refresh token that supports all features.
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REFRESH_TOKEN=your-spotify-refresh-token

# The active session ID (set each event night)
NEXT_PUBLIC_ACTIVE_SESSION_ID=your-session-uuid
